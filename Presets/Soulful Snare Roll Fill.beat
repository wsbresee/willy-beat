hihat_c  0=80, 48=55, 96=80, 144=55, 192=80, 240=55, 288=80, 336=55
hihat_o 
ride    
crash    0=120
tom_h   
tom_m   
tom_l    288=100, 336=100
rim      96=80, 192=80
