# WillyBeat Preset v2
version: 2
name:    Triplet Tom Fill
genres:  Fill, Triplet, Tom, Drum Solo, Heavy
type:    Big Fill
timesig: 4/4
bars:    1
grid:    8tr
density: 0.0563

# Hits per track as "tick=velocity" pairs. PPQN = 96.
kick     0=100
snare   
hihat_c 
hihat_o 
ride    
crash   
tom_h    0=100, 64=100, 96=100, 160=100
tom_m    192=100, 256=100, 288=100, 352=100
tom_l   
rim     
